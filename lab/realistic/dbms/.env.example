KCII_LAB_MYSQL_ROOT_PASSWORD=replace-with-temporary-mysql-lab-password

KCII_LAB_MARIADB_DATABASE=kcii_lab
KCII_LAB_MARIADB_ROOT_PASSWORD=replace-with-temporary-mariadb-lab-password
